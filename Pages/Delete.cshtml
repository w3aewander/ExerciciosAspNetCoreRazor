@page
@model DeleteModel


@{
    ViewData["Title"] = "Excluir Produto";
}

<div class="container">
    <h1>Excluir Produto</h1>

    <div class="alert alert-warning">
        Tem a certeza que deseja excluir este produto?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Produto.Nome</dd>

        <dt class="col-sm-2">Preço</dt>
        <dd class="col-sm-10">@Model.Produto.Preco.ToString("C")</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Produto.Id" />

        <button type="submit" class="btn btn-danger">
            Excluir
        </button>
        <a asp-page="Index" class="btn btn-secondary ms-2">
            Cancelar
        </a>
    </form>
</div>