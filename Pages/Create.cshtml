@page
@model MinhaAppSqlite.Pages.CreateModel
@{
    ViewData["Title"] = "Criar novo Produto";
}


<div class="container">
    <h1>Criando novo Produto</h1>

    <form method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label asp-for="Produto.Nome" class="form-label">Nome do produto</label>
            <input asp-for="Produto.Nome" class="form-control" placeholder="Informe o nome do produto" />
            <span asp-validation-for="Produto.Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Produto.Preco" class="form-label">Preço</label>
            <input asp-for="Produto.Preco" type="number" step="0.01" min="0" class="form-control" />
            <span asp-validation-for="Produto.Preco" class="text-danger"></span>
        </div>


        <input class="btn btn-primary" type="submit" value="Salvar" />
        <a asp-page="Index" class="btn btn-secondary">Voltar para o inicio</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
